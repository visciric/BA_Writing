@article{elsackerRecentTechnologicalInnovations2023,
  title = {Recent Technological Innovations in Mycelium Materials as Leather Substitutes: A Patent Review},
  shorttitle = {Recent Technological Innovations in Mycelium Materials as Leather Substitutes},
  author = {Elsacker, Elise and Vandelook, Simon and Peeters, Eveline},
  date = {2023-08-07},
  journaltitle = {Frontiers in Bioengineering and Biotechnology},
  shortjournal = {Front. Bioeng. Biotechnol.},
  volume = {11},
