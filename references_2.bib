@article{WangDeeplearning2024,
  title = {Deep Learning for Endometrial Cancer Subtyping and Predicting Tumor Mutational Burden from Histopathological Slides},
  author = {Wang, Ching-Wei and Firdi, Nabila Puspita and Lee, Yu-Ching and Chu, Tzu-Chiao and Muzakky, Hikam and Liu, Tzu-Chien and Lai, Po-Jen and Chao, Tai-Kuang},
  date = {2024-12-21},
  journaltitle = {npj Precision Oncology},
  shortjournal = {npj Precis. Onc.},
  volume = {8},
  number = {1},
  pages = {287},
  publisher = {Nature Publishing Group},
  issn = {2397-768X},
  doi = {10.1038/s41698-024-00766-9},
  url = {https://www.nature.com/articles/s41698-024-00766-9},
  urldate = {2025-09-22},
  abstract = {Endometrial cancer (EC) diagnosis traditionally relies on tumor morphology and nuclear grade, but personalized therapy demands a deeper understanding of tumor mutational burden (TMB), i.e., a key biomarker for immune checkpoint inhibition and immunotherapy response. Traditional TMB prediction methods, such as sequencing exomes or whole genomes, are costly and often unavailable in clinical settings. We present the first TR-MAMIL deep learning framework to predict TMB status and classify the EC cancer subtype directly from H\&E-stained WSIs, enabling effective personalized immunotherapy planning and prognostic refinement of EC patients. Our models were evaluated on a large dataset from The Cancer Genome Atlas. TR-MAMIL performed exceptionally well in classifying aggressive and non-aggressive EC, as well as predicting TMB, outperforming seven state-of-the-art approaches. It also performed well in classifying normal and abnormal p53 mutations in EC using H\&E WSIs. Kaplan–Meier analysis further demonstrated TR-MAMIL’s ability to differentiate patients with longer survival in the aggressive EC.},
  langid = {english},
  keywords = {⌛,😬,Cancer immunotherapy,Endometrial cancer,Prognostic markers,Tumour biomarkers},
  file = {C:\Users\ricca\Zotero\storage\GMIBGTY9\Wang et al. - 2024 - Deep learning for endometrial cancer subtyping and predicting tumor mutational burden from histopath.pdf}
}

