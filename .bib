@article{DouSinglenucleotidevariant2024,
  title = {Single-Nucleotide Variant Calling in Single-Cell Sequencing Data with {{Monopogen}}},
  author = {Dou, Jinzhuang and Tan, Yukun and Kock, Kian Hong and Wang, Jun and Cheng, Xuesen and Tan, Le Min and Han, Kyung Yeon and Hon, Chung-Chau and Park, Woong-Yang and Shin, Jay W. and Jin, Haijing and Wang, Yujia and Chen, Han and Ding, Li and Prabhakar, Shyam and Navin, Nicholas and Chen, Rui and Chen, Ken},
  date = {2024-05},
  journaltitle = {Nature Biotechnology},
