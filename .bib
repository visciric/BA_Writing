@article{MarotIdentifyingcancer2024,
  title = {Identifying Cancer Cells from Calling Single-Nucleotide Variants in {{scRNA-seq}} Data},
  author = {Marot-Lassauzaie, Valérie and Beneyto-Calabuig, Sergi and Obermayer, Benedikt and Velten, Lars and Beule, Dieter and Haghverdi, Laleh},
  date = {2024-09-01},
