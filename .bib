  title = {De Novo Detection of Somatic Mutations in High-Throughput Single-Cell Profiling Data Sets},
  author = {Muyas, Francesc and Sauer, Carolin M. and Valle-Inclán, Jose Espejo and Li, Ruoyan and Rahbari, Raheleh and Mitchell, Thomas J. and Hormoz, Sahand and Cortés-Ciriano, Isidro},
