}

@article{OsoriSystematicdetermination2020,
  title = {Systematic Determination of the Mitochondrial Proportion in Human and Mice Tissues for Single-Cell {{RNA-sequencing}} Data Quality Control},
  author = {Osorio, Daniel and Cai, James J},
